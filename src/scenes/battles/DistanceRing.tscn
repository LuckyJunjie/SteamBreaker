[gd_scene load_steps=3 format=3 uid="uid://distance_ring"]

[sub_resource type="GDScript" id="GDScript_ring"]
script/source = "extends Node2D

var radius: float = 100.0
var ring_color: Color = Color(0.8, 0.6, 0.2, 0.6)
var line_width: float = 2.0

func _draw():
    var count: int = 4
    for i in range(1, count + 1):
        var r: float = radius * float(i) / float(count)
        var alpha: float = ring_color.a * (1.0 - float(i) / float(count + 1))
        draw_arc(Vector2.ZERO, r, 0, TAU, 64, Color(ring_color.r, ring_color.g, ring_color.b, alpha), line_width, true)

func SetRadius(r: float):
    radius = r
    queue_redraw()

func SetColor(c: Color):
    ring_color = c
    queue_redraw()
"

[node name="DistanceRing" type="Node2D"]
script = SubResource("GDScript_ring")
